# =============================================================================
# OpenKai Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Only configure the connectors and services you actually use.

# --- LLM Provider ---
# At least one LLM provider is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- OpenKai Core ---
OPENKAI_LOCALE=en                    # en | es
OPENKAI_LOG_LEVEL=info               # debug | info | warn | error

# --- SIEM Connectors ---
# Splunk
SPLUNK_URL=
SPLUNK_TOKEN=
SPLUNK_INDEX=main

# Elasticsearch
ELASTIC_URL=
ELASTIC_API_KEY=
ELASTIC_INDEX=security-*

# Microsoft Sentinel
SENTINEL_WORKSPACE_ID=
SENTINEL_TENANT_ID=
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=

# --- EDR Connectors ---
# CrowdStrike
CROWDSTRIKE_CLIENT_ID=
CROWDSTRIKE_CLIENT_SECRET=
CROWDSTRIKE_BASE_URL=https://api.crowdstrike.com

# --- Vulnerability Scanners ---
# Qualys
QUALYS_URL=
QUALYS_USERNAME=
QUALYS_PASSWORD=

# Tenable
TENABLE_ACCESS_KEY=
TENABLE_SECRET_KEY=
TENABLE_URL=https://cloud.tenable.com

# Nessus
NESSUS_URL=
NESSUS_API_KEY=

# Wiz
WIZ_CLIENT_ID=
WIZ_CLIENT_SECRET=
WIZ_API_URL=

# Orca
ORCA_API_KEY=
ORCA_API_URL=

# --- AppSec Connectors ---
# Snyk
SNYK_TOKEN=
SNYK_ORG_ID=

# Semgrep
SEMGREP_APP_TOKEN=

# SonarQube
SONARQUBE_URL=
SONARQUBE_TOKEN=

# GitHub Advanced Security
GITHUB_TOKEN=
GITHUB_ORG=

# --- ITSM Connectors ---
# Jira
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ServiceNow
SERVICENOW_INSTANCE=
SERVICENOW_USERNAME=
SERVICENOW_PASSWORD=

# --- Messaging Channels (OpenClaw native) ---
# Configure these in OpenClaw's config directly, or set here:
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
